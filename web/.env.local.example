# Copy to .env.local and fill in. Required for the app to run.

# AssemblyAI — transcription + diarization + sentiment
ASSEMBLYAI_API_KEY=

# OpenRouter — summary, task generation, chat
OPENROUTER_API_KEY=
# Pin an available model id; default is gemini flash. Cheaper: google/gemini-flash-1.5, deepseek/deepseek-chat
OPENROUTER_MODEL=google/gemini-2.5-flash

# Muninn memory layer (MCP JSON-RPC over HTTPS). On winnr itself use http://localhost:8750/mcp
MUNINN_URL=https://winnr.tailf82123.ts.net/mcp
MUNINN_TOKEN=mk_your_vault_api_key_here
MUNINN_VAULT=winnr-meetings
